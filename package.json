{
  "name": "forensics-in-tab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-only forensic triage for disk images, memory dumps, YARA rules, and disassembly without uploading evidence.",
  "homepage": "https://baditaflorin.github.io/forensics-in-tab/",
  "repository": {
    "type": "git",
    "url": "https://github.com/baditaflorin/forensics-in-tab.git"
  },
  "bugs": {
    "url": "https://github.com/baditaflorin/forensics-in-tab/issues"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/write-build-info.mjs && node scripts/prepare-pages.mjs",
    "build": "tsc -b && vite build && node scripts/validate-pages.mjs",
    "pages-preview": "http-server docs -p 4173 -c-1",
    "lint": "eslint . && prettier --check .",
    "fmt": "prettier --write .",
    "test": "vitest run --coverage=false",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "smoke": "bash scripts/smoke.sh"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.12",
    "capstone-wasm": "^1.0.3",
    "lucide-react": "^0.556.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "http-server": "^14.1.1",
    "jsdom": "^27.2.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.47.0",
    "vite": "^7.2.6",
    "vitest": "^4.0.15"
  }
}
